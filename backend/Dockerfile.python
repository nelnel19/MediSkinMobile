FROM python:3.11-slim

WORKDIR /app

# Copy Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy ONLY Python-related files
COPY main.py database.py ./
# Copy ONLY the Keras model, not the Node.js model files
COPY models/skin_disease_mobilenet.keras ./models/

# Expose the port (documentation only)
EXPOSE 10000

# Start the FastAPI server using the PORT environment variable
CMD uvicorn main:app --host 0.0.0.0 --port ${PORT:-10000}